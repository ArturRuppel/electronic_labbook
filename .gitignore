# ---------------------------------------------------------------------------
# Databases are BUILD ARTIFACTS, never committed.
# The versioned, line-diffable form lives in the *data* repo as experiments.sql
# and is rebuilt into experiments.db by rebuild_db.py.
# ---------------------------------------------------------------------------
*.db
*.db.bak
*.db-wal
*.db-shm
*.backup-*

# Local unified config (ship labbook.toml.example; users copy it to labbook.toml)
labbook.toml

# Generated static catalog pages (produced by the generators at build time).
# Static frontend assets that happen to be .html (templates, graph view) are
# negated below so they stay tracked.
catalog/*.html
!catalog/home_template.html
!catalog/sdgl.html

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.venv/

# Packaging / tooling
build/
dist/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# IDEs / editors
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.log

# Agent / MCP tool caches
.serena/
