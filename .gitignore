build/
dist/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# IDEs / editors
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.log

