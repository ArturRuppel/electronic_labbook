# SDGL configuration — TEMPLATE.
#
# Copy this file to `sdgl.toml` (which is gitignored) and edit the paths to
# point at YOUR data. Nothing here is hardcoded in the code; every path the
# scanner touches is read from this file.
#
#   cp sdgl.toml.example sdgl.toml
#
# Paths may be relative (resolved against the repo root) or absolute.

[scanner]
# Run a scan automatically when the server starts.
run_on_startup = false
# Run a scan once per day.
daily_scan = false

# ---------------------------------------------------------------------------
# Scan roots: each is a named location the SDGL engine walks. The first two
# (content that ships in the data repo) are relative; the rest are examples of
# absolute external data locations — replace or delete them for your setup.
# ---------------------------------------------------------------------------

[[scan_roots]]
name = "reports"
path = "reports"

[[scan_roots]]
name = "presentations"
path = "presentations"

# --- Example external data roots (EDIT THESE) ------------------------------

[[scan_roots]]
name = "data"
path = "/path/to/your/data"

[[scan_roots]]
name = "microscope-share"
path = "/path/to/your/microscope/network-share"

# [[scan_roots]]
# name = "external-drive"
# path = "/media/<user>/<drive>/"
