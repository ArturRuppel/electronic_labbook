# labbook.toml — copy this to labbook.toml (gitignored) and edit for your machine.
# This single file replaces the old data-repo sdgl.toml and adds data_root.

# Absolute path to the data repo (holds experiments.sql, reports/, ...).
data_root = "/abs/path/to/data-repo"

[scanner]
run_on_startup = false
daily_scan = false
# Content hashing: store a SHA-256 per file on scan for
# tamper-evidence and duplicate detection. Opt-in, because the first pass over a
# large raw corpus can be slow; afterwards a file is only re-hashed when its
# size or mtime changes. `labbook scan --hash` forces it on for one run, and
# `labbook verify` recomputes hashes to flag any drift.
content_hashing = false
# Optional ceiling in bytes; files larger than this are left unhashed so the
# first pass over multi-GB acquisitions stays bounded. Omit for no limit.
# hash_max_bytes = 5_000_000_000

# Directories SDGL scans for raw/derived files. Relative paths resolve against
# data_root; absolute paths (e.g. external acquisition drives) are used as-is.
[[scan_roots]]
name = "data"
path = "data"

# Channel fungibility: groups of interchangeable microscopy markers. The first
# member of each group is the canonical label; the others are treated as aliases
# of it in autocomplete suggestions. Optional — omit if you don't use it.
# [channels]
# aliases = [
#     ["GFP", "488", "FITC"],
#     ["RFP", "561", "mCherry"],
# ]

# RFC 3161 trusted timestamps (layer 3). On `labbook publish`,
# a SHA-256 digest of the published snapshot is anchored to a signed token from
# a Time Stamping Authority and committed under timestamps/ — cryptographic
# proof-of-existence-at-a-time that even git can't provide. Best-effort: a TSA
# outage records a "pending" entry (retry with `labbook timestamp --retry`) and
# never blocks publishing. `labbook verify` checks the tokens. Enabled by
# default; the defaults below need no [timestamp] section at all.
# [timestamp]
# enabled = true
# tsa_url = "http://timestamp.digicert.com"  # free, RSA-signed, no auth
# tsa_cert = ""  # path to trusted-root PEM; empty uses the bundled DigiCert root

# Sharing / export. `labbook export` writes a self-contained,
# relative-linked static HTML bundle you can drop on the Gaia share (open
# index.html over file://) or host on GitHub Pages — no server needed for
# viewers. Three granularities: the whole catalog (--all), a single progress
# report (--report PATH), or a single presentation (--presentation DIRNAME),
# each to a folder you pick with --dest. The authoring view (`labbook admin`)
# also exposes an "Export catalog" button plus per-item Export buttons. Export
# only produces the folder; putting it on Gaia or Pages is a manual follow-on.
# No [export] config is required.
